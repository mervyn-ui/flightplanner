  // Deduplicate by iata
  const AP_LIST = Object.values(Object.fromEntries(AP_AIRPORTS.map(a => [a.iata, a])));

  function haversineKm(lat1, lon1, lat2, lon2) {
    const R = 6371, toRad = d => d * Math.PI / 180;
    const dLat = toRad(lat2 - lat1), dLon = toRad(lon2 - lon1);
    const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon/2)**2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
  }

  function nearbyAirports(iata, radiusKm = 200) {
    const base = AP_LIST.find(a => a.iata === iata);
    if (!base || base.lat == null) return [];
    return AP_LIST
      .filter(a => a.iata !== iata && a.lat != null)
      .map(a => ({ ...a, distKm: Math.round(haversineKm(base.lat, base.lon, a.lat, a.lon)) }))
      .filter(a => a.distKm <= radiusKm)
      .sort((a, b) => a.distKm - b.distKm)
      .slice(0, 5);
  }

  const apState = {
    from: { selected: ["BRU","EIN","AMS","NRN"], activeIdx: -1 },
    to:   { selected: ["OPO","SCQ"],             activeIdx: -1 },
  };

  function toggleNearbyChip(chip) {
    chip.classList.toggle("picked");
  }

  function addNearbyAndSearch(btn) {
    // Collect all picked chips in nearby cards
    document.querySelectorAll(".nearby-chip.picked").forEach(chip => {
      const side = chip.dataset.side;   // "from" or "to"
      const iata = chip.dataset.iata;
      if (!apState[side].selected.includes(iata)) {
        apState[side].selected.push(iata);
      }
    });
    apRenderChips("from");
    apRenderChips("to");
    apUpdateHidden("from");
    apUpdateHidden("to");
    doSearch();
  }

  function apInit() {
    ["from","to"].forEach(side => {
      apRenderChips(side);
      apUpdateHidden(side);
      apRenderList(side, "");
    });
    document.addEventListener("click", e => {
      if (!e.target.closest("#ap-from-wrap")) apClose("from");
      if (!e.target.closest("#ap-to-wrap"))   apClose("to");
    });
  }

  function apRenderChips(side) {
    const box = document.getElementById(`ap-${side}-box`);
    box.querySelectorAll(".ap-chip").forEach(c => c.remove());
    const ph = document.getElementById(`ap-${side}-ph`);
    if (apState[side].selected.length === 0) {
      ph.style.display = "";
    } else {
      ph.style.display = "none";
      apState[side].selected.forEach(iata => {
        const ap   = AP_LIST.find(a => a.iata === iata);
        const chip = document.createElement("span");
        chip.className = "ap-chip";
        chip.innerHTML = `${ap ? ap.flag : ""} ${iata} <button class="ap-chip-remove" onclick="apRemove('${side}','${iata}',event)">×</button>`;
        box.appendChild(chip);
      });
    }
  }

  function apUpdateHidden(side) {
    document.getElementById(side === "from" ? "origins" : "destinations")
      .value = apState[side].selected.join(",");
  }

  function apFocus(side) {
    document.getElementById(`ap-${side}-box`).classList.add("focused");
    document.getElementById(`ap-${side}-drop`).classList.add("open");
    const inp = document.getElementById(`ap-${side}-search`);
    inp.value = "";
    apRenderList(side, "");
    setTimeout(() => inp.focus(), 0);
  }

  function apClose(side) {
    document.getElementById(`ap-${side}-box`).classList.remove("focused");
    document.getElementById(`ap-${side}-drop`).classList.remove("open");
    document.getElementById(`ap-${side}-search`).value = "";
    apState[side].activeIdx = -1;
  }

  function apFilter(side) {
    const q = document.getElementById(`ap-${side}-search`).value;
    apRenderList(side, q);
  }

  function apRenderList(side, query) {
    const list = document.getElementById(`ap-${side}-list`);
    const q    = query.trim().toLowerCase();
    const matches = q
      ? AP_LIST.filter(a =>
          a.iata.toLowerCase().includes(q) ||
          a.city.toLowerCase().includes(q) ||
          a.name.toLowerCase().includes(q) ||
          a.country.toLowerCase().includes(q))
      : AP_LIST;

    if (!matches.length) {
      list.innerHTML = `<div class="ap-no-results">No airports found for "${query}"</div>`;
      return;
    }
    list.innerHTML = matches.slice(0, 50).map((a) => {
      const sel = apState[side].selected.includes(a.iata);
      return `<div class="ap-option${sel ? " selected" : ""}" data-iata="${a.iata}" onclick="apSelect('${side}','${a.iata}')">
        <span class="ap-flag">${a.flag}</span>
        <span class="ap-iata">${a.iata}</span>
        <span class="ap-info">
          <div class="ap-city">${a.city}</div>
          <div class="ap-name">${a.name} · ${a.country}</div>
        </span>
        <span class="ap-check">${sel ? "✓" : ""}</span>
      </div>`;
    }).join("");
    apState[side].activeIdx = -1;
  }

  function apSelect(side, iata) {
    const sel = apState[side].selected;
    const idx = sel.indexOf(iata);
    if (idx === -1) sel.push(iata); else sel.splice(idx, 1);
    apRenderChips(side);
    apUpdateHidden(side);
    const q = document.getElementById(`ap-${side}-search`).value;
    apRenderList(side, q);
    document.getElementById(`ap-${side}-search`).focus();
  }

  function apRemove(side, iata, event) {
    event.stopPropagation();
    const sel = apState[side].selected;
    const idx = sel.indexOf(iata);
    if (idx !== -1) sel.splice(idx, 1);
    apRenderChips(side);
    apUpdateHidden(side);
  }

  function apKey(event, side) {
    const list    = document.getElementById(`ap-${side}-list`);
    const options = list.querySelectorAll(".ap-option");
    if (!options.length) return;
    if (event.key === "ArrowDown") {
      event.preventDefault();
      apState[side].activeIdx = Math.min(apState[side].activeIdx + 1, options.length - 1);
    } else if (event.key === "ArrowUp") {
      event.preventDefault();
      apState[side].activeIdx = Math.max(apState[side].activeIdx - 1, 0);
    } else if (event.key === "Enter" && apState[side].activeIdx >= 0) {
      event.preventDefault();
      apSelect(side, options[apState[side].activeIdx].dataset.iata);
      return;
    } else if (event.key === "Escape") {
      apClose(side); return;
    } else { return; }
    options.forEach((o, i) => o.classList.toggle("active", i === apState[side].activeIdx));
    options[apState[side].activeIdx]?.scrollIntoView({ block: "nearest" });
  }

  // ── My Trips / Booking confirmation ──────────────────────────

  function getTrips() {
    try { return JSON.parse(localStorage.getItem("udra_trips") || "[]"); }
    catch(e) { return []; }
  }

  function saveTrips(trips) {
    localStorage.setItem("udra_trips", JSON.stringify(trips));
  }

  function isFlightBooked(key) {
    return getTrips().some(t => t.key === key);
  }

  function confirmFlight(event, cardEl) {
    // <a> still opens the booking URL in new tab; we just also save locally
    const data = JSON.parse(decodeURIComponent(cardEl.dataset.card));
    const key  = `${data.origin}-${data.destination}-${data.depart_date}`;
    if (isFlightBooked(key)) return;
    const trips = getTrips();
    trips.push({ ...data, key, confirmedAt: Date.now() });
    saveTrips(trips);
    updateTripsCount();
    // Flip just this card in-place: badge → BOOKED, Book link → Unconfirm button
    const center = cardEl.querySelector(".topbar-center");
    if (center) center.innerHTML = `<span class="badge badge-booked">✓ Booked</span>`;
    const bookLink = cardEl.querySelector(".bekijk-deal-btn");
    if (bookLink) {
      const ub = document.createElement("button");
      ub.className   = "unconfirm-btn";
      ub.textContent = "✗ Unconfirm";
      ub.onclick     = () => unconfirmFlight(key);
      bookLink.replaceWith(ub);
    }
  }

  function unconfirmFlight(key) {
    const trips = getTrips().filter(t => t.key !== key);
    saveTrips(trips);
    updateTripsCount();
    // Remove the card from My Trips
    renderMyTrips();
    // Flip matching card in search results back to Book if still visible
    document.querySelectorAll(".flight-card").forEach(cardEl => {
      try {
        const d = JSON.parse(decodeURIComponent(cardEl.dataset.card || "{}"));
        const k = `${d.origin}-${d.destination}-${d.depart_date}`;
        if (k !== key) return;
        const center = cardEl.querySelector(".topbar-center");
        if (center) center.innerHTML = ""; // clear BOOKED badge
        const ub = cardEl.querySelector(".unconfirm-btn");
        if (ub) {
          const link = document.createElement("a");
          link.className = "bekijk-deal-btn";
          link.href      = d.booking_url;
          link.target    = "_blank";
          link.textContent = "Book";
          link.onclick   = (ev) => confirmFlight(ev, cardEl);
          ub.replaceWith(link);
        }
      } catch(e) {}
    });
  }

  function updateTripsCount() {
    const n   = getTrips().length;
    const badge = document.getElementById("trips-count");
    badge.textContent = n;
    badge.style.display = n > 0 ? "" : "none";
  }

  function showTab(tab) {
    document.getElementById("results").style.display  = tab === "search" ? "block" : "none";
    document.getElementById("mytrips").style.display  = tab === "trips"  ? "block" : "none";
    document.getElementById("tab-search").classList.toggle("active", tab === "search");
    document.getElementById("tab-trips").classList.toggle("active",  tab === "trips");
    if (tab === "trips") renderMyTrips();
  }

  function fmtTripDate(iso) {
    if (!iso) return "";
    const [y,m,d] = iso.split("-");
    const M = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    return `${+d} ${M[+m-1]}`;
  }

  function fmtConfirmedAt(ts) {
    if (!ts) return "";
    const d = new Date(ts);
    return d.toLocaleDateString("nl-NL", { day: "numeric", month: "short" });
  }

  function buildMyTripCard(trip) {
    const parkosUrl = buildParkosUrl(trip.origin, trip.depart_date, trip.dep_time, trip.return_date, trip.ret_arr_time);
    const rentalUrl = rentalUrlForFlight(trip, trip.depart_date, trip.return_date);
    const flights   = buildCard(trip, trip.depart_date, trip.return_date);
    return `
      <div class="flight-card mytrip-card">
        <div class="card-topbar">
          <div class="topbar-left">
            <button class="icon-btn">♡</button>
          </div>
          <div class="topbar-center">
            <span class="badge badge-booked">✓ Booked</span>
          </div>
          <div class="topbar-right">
            <div class="luggage-btn"><span>🧳</span> 0</div>
            <div class="luggage-btn"><span>🎒</span> 0</div>
          </div>
        </div>
        <div class="card-body">
          <div class="card-flights">${flights}</div>
          <div class="card-price">
            <div class="price-amount">€ ${trip.price ?? "—"}</div>
            <div class="price-tier">Basic</div>
            <a class="bekijk-deal-btn" href="${trip.booking_url}" target="_blank">Book</a>
            <a class="rental-card-btn" href="${rentalUrl}" target="_blank">🚗 Rent a car</a>
            ${parkosUrl ? `<a class="parkos-card-btn" href="${parkosUrl}" target="_blank">🅿 Parking</a>` : ""}
            <button class="unconfirm-btn" onclick="unconfirmFlight('${trip.key}')">✗ Unconfirm</button>
          </div>
        </div>
        <div class="mytrip-tg" id="mytrip-tg-${trip.key.replace(/[^a-zA-Z0-9]/g,'_')}">
          <div class="mytrip-tg-loading">⏳ Loading travel guide…</div>
        </div>
        <div class="card-footer">${trip.airline} · confirmed ${fmtConfirmedAt(trip.confirmedAt)}</div>
      </div>`;
  }

  async function renderMyTrips() {
    const wrap = document.getElementById("mytrips");
    const trips = getTrips();
    if (!trips.length) {
      wrap.innerHTML = `<div class="error-card" style="text-align:center;padding:2rem;">No booked trips yet.<br><small style="color:#aaa">Click <strong>Book</strong> on any flight to confirm it here.</small></div>`;
      return;
    }
    wrap.innerHTML = trips.map(buildMyTripCard).join("");
    // Async-load travel guide for each card
    trips.forEach(trip => {
      const tgId = `mytrip-tg-${trip.key.replace(/[^a-zA-Z0-9]/g,'_')}`;
      loadMyTripTG(trip, tgId);
    });
  }

  async function loadMyTripTG(trip, tgId) {
    const el = document.getElementById(tgId);
    if (!el) return;
    try {
      const params = new URLSearchParams({
        dep_airport: trip.dep_airport || trip.origin,
        dep_time:    trip.dep_time,
        dep_date:    trip.depart_date,
        arr_airport: trip.arr_airport || trip.destination,
        ret_dep_time: trip.ret_dep_time || "",
        ret_dep_date: trip.return_date  || "",
      });
      const res  = await fetch(`/travel_guide?${params}`);
      const data = await res.json();
      const fmtDate = s => { if (!s) return ""; const [y,m,d] = s.split("-"); const M=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"]; return `${+d} ${M[+m-1]}`; };
      const row  = (label, value) => value
        ? `<div class="tg-row"><span class="tg-label">${label}</span><span class="tg-value">${value}</span></div>`
        : "";
      let leftCol = "", rightCol = "";
      if (data.outbound) {
        const o = data.outbound;
        leftCol = `
          <div class="tg-col-title">✈ Leave &nbsp;·&nbsp; ${fmtDate(o.date)}</div>
          ${row("🏠 Leave home",               o.leave)}
          ${row("🚗 Arrive " + o.dep_airport_name, o.arrive_airport)}
          ${row("🛫 Departure",                o.departure)}
          ${trip.arr_time ? row("🛬 Arrive " + o.arr_airport_name, trip.arr_time) : ""}`;
      }
      if (data.return) {
        const r = data.return;
        rightCol = `
          <div class="tg-col-title">✈ Return &nbsp;·&nbsp; ${fmtDate(r.date)}</div>
          ${row("🏠 Leave",                    r.leave)}
          ${row("🚗 Arrive " + r.dep_airport_name, r.arrive_airport)}
          ${row("🛫 Departure",                r.departure)}
          ${trip.ret_arr_time ? row("🛬 Arrive " + r.arr_airport_name, trip.ret_arr_time) : ""}`;
      }
      const calData = JSON.stringify({
        dep: trip.depart_date, ret: trip.return_date,
        origin: trip.origin, dest: trip.destination,
        deptime: trip.dep_time, arrtime: trip.arr_time,
        retdep: trip.ret_dep_time, retarr: trip.ret_arr_time,
        price: "", airline: "",
      });
      el.innerHTML = `
        <div class="tg-cols">
          <div>${leftCol || "<span style='color:#aaa'>No outbound data</span>"}</div>
          <div>${rightCol}</div>
        </div>
        <div class="tg-footer">
          <button class="tg-cal-btn" onclick="openCalendarFromPanel(this)" data-tg='${encodeURIComponent(calData)}'>📅 Add to calendar</button>
        </div>`;
    } catch(e) {
      el.innerHTML = `<div class="mytrip-tg-loading">Travel guide unavailable</div>`;
    }
  }

  document.addEventListener("DOMContentLoaded", () => { apInit(); updateTripsCount(); });
</script>

</body>
</html>
